            placeholder: "e.g. Vineet Pal",
            prefixOptions: { icon: "user" }
        });

        $("#email").kendoTextBox({ 
            placeholder: "example@domain.com",
            prefixOptions: { icon: "email" }
        });

        $("#password").kendoTextBox({ 
            placeholder: "Minimum 8 characters",
            prefixOptions: { icon: "lock" }
        });

