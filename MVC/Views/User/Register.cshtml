            var email = $("#email").val();
            
            if (!empName || !email) {
                e.preventDefault();
                Swal.fire({
                    icon: 'warning',
                    title: 'Missing Information',
                    text: 'Please fill in all mandatory fields!',
                    confirmButtonColor: '#3f51b5'
                });
            }
        });

        // 6. This part describes the success notification here from the backend
        @if (TempData["msg"] != null)
        {
            <text>
            Swal.fire({
                icon: 'success',
                title: 'Success!',
                text: '@TempData["msg"]',
                timer: 3000,
                showConfirmButton: false,
                toast: true,
                position: 'top-end'
            });
            </text>
        }
    });
</script>
} *@



