@{
    ViewData["Title"] = "My Performance Metrics";
    Layout="_EmployeeLayout";
}

<div class="container-fluid mt-4">
    <div class="row mb-4">
        <div class="col-md-12">
            <h2 class="k-h2">Personal Performance Insights</h2>
            <p class="text-muted">A real-time overview of your query resolution efficiency and workload.</p>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-4">
            <div class="k-card shadow-sm text-center p-3">
                <div id="resolutionGauge"></div>
                <h4 class="mt-2">Resolution Rate</h4>
            </div>
        </div>
        <div class="col-md-4">
            <div class="k-card shadow-sm p-3">
                <div id="statusDonut"></div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="k-card shadow-sm p-3 text-center">
                <h1 class="display-1 text-primary font-weight-bold" id="totalSolved">42</h1>
                <p class="text-muted">Total Queries Solved This Month</p>
                <hr />
                <h3 class="text-success">Rank #2</h3>
                <p>Top Performer Leaderboard</p>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <div class="k-card shadow-sm p-3">
                <div id="productivityChart"></div>
            </div>
        </div>
    </div>
</div>

<style>
    .k-card { border-radius: 12px; border: none; background: #ffffff; }
    #resolutionGauge { height: 180px; margin: 0 auto; }
    #statusDonut { height: 250px; }
    #productivityChart { height: 350px; }
</style>

@section Scripts {
    <script>
        $(document).ready(function () {
            // 1. Radial Gauge: Resolution Rate (e.g., 85%)
            $("#resolutionGauge").kendoRadialGauge({
                pointer: { value: 85 },
                scale: {
                    minorUnit: 5,
                    startAngle: -30,
                    endAngle: 210,
                    max: 100,
                    labels: { position: "inside" },
                    ranges: [
                        { from: 0, to: 40, color: "#ffc107" },
                        { from: 40, to: 80, color: "#17a2b8" },
                        { from: 80, to: 100, color: "#28a745" }
                    ]
                }
            });

            // 2. Donut Chart: Status Distribution
            $("#statusDonut").kendoChart({
                title: { text: "Ticket Status Share" },
                legend: { position: "bottom" },
                seriesDefaults: { type: "donut" },
                series: [{
                    name: "Queries",
                    data: [
                        { category: "Solved", value: 42, color: "#28a745" },
                        { category: "In Progress", value: 12, color: "#17a2b8" },
                        { category: "Open", value: 5, color: "#ffc107" }
                    ]
                }],
                tooltip: { visible: true, template: "#= category # (#= value #)" }
            });

            // 3. Bar Chart: Weekly Productivity Trend
            $("#productivityChart").kendoChart({
                title: { text: "Queries Resolved (Last 7 Days)" },
                legend: { position: "top" },
                series: [{
                    name: "Resolved",
                    data: [4, 7, 5, 8, 3, 9, 6],
                    color: "#3f51b5"
                }],
                valueAxis: {
                    line: { visible: false },
                    minorGridLines: { visible: true }
                },
                categoryAxis: {
                    categories: ["Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun"],
                    majorGridLines: { visible: false }
                },
                tooltip: { visible: true, format: "{0} resolved" }
            });
        });
    </script>
}