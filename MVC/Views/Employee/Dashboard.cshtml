        // 2. Data Loading & Chart Logic
        function loadDashboardData() {
            $.get("@Url.Action("GetPersonalMetrics", "Employee")", function (data) {
                // Update Numeric Displays
                console.log("Data from server:", data);
                $("#headerSolvedCount, #leaderboardCount").text(data.solvedCount);
                $("#systemActive").text(data.activeCount);
                $("#urgentCount").text(data.urgentCount);

                let rate = data.activeCount > 0 ? Math.round((data.solvedCount / (data.solvedCount + data.activeCount)) * 100) : 100;
                $("#resRatePercent").text(rate + "%");

                // Initialize Gauge
                $("#resolutionGauge").kendoRadialGauge({
                    pointer: { value: rate },
                    scale: {
                        max: 100,
                        ranges: [
                            { from: 0, to: 40, color: "#dc3545" },
                            { from: 40, to: 80, color: "#ffc107" },
                            { from: 80, to: 100, color: "#28a745" }
                        ]
                    }
                });

                // Initialize Donut
                $("#statusDonut").kendoChart({
                    legend: { position: "bottom" },
                    series: [{
                        type: "donut",
                        data: [
                            { category: "Solved", value: data.solvedCount, color: "#28a745" },
                            { category: "Pending", value: data.activeCount, color: "#ffc107" },
                            { category: "Urgent", value: data.urgentCount, color: "#dc3545" }
                        ]
                    }],
                    tooltip: { visible: true, template: "${category}: ${value}" }
                });

                // Initialize Weekly Trend (Sample Data)
                $("#productivityChart").kendoChart({
                    series: [{ name: "Resolved", data: [4, 7, 5, 8, data.solvedCount % 10, data.solvedCount % 10, data.solvedCount % 10], color: "#764ba2" }],
                    categoryAxis: { categories: ["Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun"] },
                    tooltip: { visible: true, format: "{0} resolved" }
                });
            });
        }

        function renderPriority(p) {
            let color = p === "High" ? "danger" : (p === "Medium" ? "warning" : "info");
            return `<span class="badge-priority bg-${color}20 text-${color} border border-${color}">${p}</span>`;
        }
    </script>
} 



