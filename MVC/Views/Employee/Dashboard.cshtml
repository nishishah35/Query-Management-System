@section Scripts {
    <script>
        $(document).ready(function () {
            $("#mainTabStrip").kendoTabStrip({ animation: { open: { effects: "fadeIn" } } });
            loadDashboardData();

            $("#unsolvedGrid").kendoGrid({
                dataSource: {
                    transport: {
                        read: { url: "@Url.Action("GetUnsolvedQueries", "Employee")", dataType: "json" },
                        update: { url: "@Url.Action("UpdateQueryStatus", "Employee")", type: "POST", dataType: "json" }
                    },
                    schema: { model: { id: "c_QueryId" } },
                    pageSize: 8
                },
                pageable: true,
                sortable: true,
                columns: [
                    { field: "c_Title", title: "Issue", width: "40%" },
                    { field: "c_Priority", title: "Priority", width: "15%", template: p => renderPriority(p.c_Priority) },
                    { field: "c_Status", title: "Status", width: "15%" },
                    { command: [{ name: "edit", text: "Process" }], title: "Action", width: "120px" }
                ],
                editable: { mode: "popup", template: kendo.template($("#resolveTemplate").html()) },
                save: () => setTimeout(loadDashboardData, 800)
            });
        });

        function loadDashboardData() {
            // Using the endpoint that returns all 3 metrics
            $.get("@Url.Action("GetPersonalAnalytics", "Employee")", function (data) {
                $("#headerSolvedCount, #leaderboardCount").text(data.solvedCount);
                $("#systemActive").text(data.activeCount);
                $("#urgentCount").text(data.urgentCount);
                
                let rate = (data.solvedCount + data.activeCount) > 0 ? 
                    Math.round((data.solvedCount / (data.solvedCount + data.activeCount)) * 100) : 100;
                $("#resRatePercent").text(rate + "%");

                initCharts(rate, data);
            });
        }

        function initCharts(rate, data) {
            $("#resolutionGauge").kendoRadialGauge({
                pointer: { value: rate, color: "#4f46e5" },
                scale: { 
                    max: 100, 
                    ranges: [
                        { from: 0, to: 40, color: "#ef4444" },
                        { from: 40, to: 80, color: "#f59e0b" },
                        { from: 80, to: 100, color: "#10b981" }
                    ] 
                }
            });

            $("#statusDonut").kendoChart({
                seriesDefaults: { type: "donut", holeSize: 60 },
                series: [{
                    data: [
                        { category: "Solved", value: data.solvedCount, color: "#10b981" },
                        { category: "Pending", value: data.activeCount, color: "#f59e0b" },
                        { category: "Urgent", value: data.urgentCount, color: "#ef4444" }
                    ]
                }],
                tooltip: { visible: true, template: "#= category #: #= value #" }
            });

            $("#productivityChart").kendoChart({
                series: [{ type: "area", name: "Resolved", data: [5, 8, 6, 10, 4, 12, data.solvedCount % 15], color: "#6366f1", opacity: 0.3 }],
                categoryAxis: { categories: ["Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun"], majorGridLines: { visible: false } },
                valueAxis: { labels: { step: 2 }, line: { visible: false } },
                chartArea: { background: "transparent" }
            });
        }

        function renderPriority(p) {
            let color = p === "High" ? "danger" : (p === "Medium" ? "warning" : "info");
            return `<span class="badge-priority bg-${color}20">${p}</span>`;
        }
    </script>
} *@